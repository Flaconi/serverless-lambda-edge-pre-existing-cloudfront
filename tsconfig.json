{
    "compilerOptions": {
      "module": "esnext",
      "outDir": "dist",
      "target": "es2021",
      "declaration": true,
      "esModuleInterop": true,
      "resolveJsonModule": true,
      "moduleResolution": "node",
      "noLib": false,
      "lib": [
        "esnext",
        "dom"
      ]
    },
    "include": [
      "src/**.ts",
    ],
    "exclude": [
      "node_modules"
    ]
  }